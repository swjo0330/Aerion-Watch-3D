# ── Docker Compose 루트 환경변수 ──────────────────────────────────────────
# 이 파일을 .env 로 복사 후 수정하세요: cp .env.example .env

# 포트 설정
BACKEND_PORT=8000
FRONTEND_PORT=3000

# 브라우저에서 접근하는 WebSocket URL (호스트 머신 기준)
# 원격 서버 배포 시: ws://your-server-ip:8000/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Cesium Ion 토큰 (옵션)
NEXT_PUBLIC_CESIUM_ION_TOKEN=
