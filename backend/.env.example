# ── JWT 설정 ──────────────────────────────────────────────────────────────
# 프로덕션에서 반드시 강력한 랜덤 값으로 교체
JWT_SECRET_KEY=change-me-to-a-strong-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── 서버 설정 ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# 허용할 CORS 오리진 (JSON 배열 형식)
ALLOWED_ORIGINS=["http://localhost:3000","https://your-domain.com"]

# ── WebSocket ─────────────────────────────────────────────────────────────
WS_MAX_CONNECTIONS=50
RATE_LIMIT_PER_SECOND=100

# ── MAVLink (실제 드론 연결 시) ───────────────────────────────────────────
MAVLINK_UDP_PORT=14550

# ── Cesium Ion (3D 지형/위성 이미지용) ────────────────────────────────────
# https://ion.cesium.com 에서 무료 토큰 발급
CESIUM_ION_TOKEN=

# ── Redis (Phase 5 수평 확장 시 사용) ────────────────────────────────────
REDIS_URL=redis://redis:6379
